# ── Frontend (required — add in Vercel → Settings → Environment Variables) ──
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key
VITE_APP_URL=https://your-app.vercel.app
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
VITE_STRIPE_PRICE_STARTER_MONTHLY=price_...
VITE_STRIPE_PRICE_GROWTH_MONTHLY=price_...
VITE_STRIPE_PRICE_PRO_MONTHLY=price_...
VITE_STRIPE_PRICE_STARTER_ANNUAL=price_...
VITE_STRIPE_PRICE_GROWTH_ANNUAL=price_...
VITE_STRIPE_PRICE_PRO_ANNUAL=price_...
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_META_PIXEL_ID=000000000000000

# ── Server-only (Vercel env vars — never expose in frontend) ──
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Required for account deletion API — find in Supabase → Project Settings → API → service_role (secret)
META_CONVERSIONS_API_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxx
META_PIXEL_ID=000000000000000
# Optional — use while testing in Meta Events Manager → Test Events
META_TEST_EVENT_CODE=TEST12345
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
ANTHROPIC_API_KEY=sk-ant-...
RESEND_API_KEY=re_xxxxxxxxxx
CONTACT_FROM_EMAIL=ApexManager <noreply@apexmanager.app>
CONTACT_TO_EMAIL=support@apexmanager.app
